# ============================================================
#  STAGING — copia esto a .env en el VPS de staging
#  Diferencias clave vs producción:
#    - DAILY_SPEND_CAP reducido (0.50 USD)
#    - FORCE_RUN_CYCLE=true (ciclo inmediato al arrancar)
#    - JWT_SECRET distinto al de producción
#    - Telegram bot separado (opcional)
# ============================================================

# --- Base de datos ---
DB_USER=qilin
DB_PASSWORD=changeme_staging

# --- JWT ---
JWT_SECRET=staging_secret_change_this_32chars_min

# --- OpenSky Network ---
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=

# --- Telegram Bot (staging — puede ser el mismo bot o uno distinto) ---
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# --- Intervalos de polling (más lentos en staging para ahorrar cuota) ---
ADSB_POLL_INTERVAL=30
AIS_POLL_INTERVAL=120
SOCIAL_POLL_INTERVAL=1800
NEWS_POLL_INTERVAL=1800
DOCS_POLL_INTERVAL=7200
SEC_POLL_INTERVAL=3600
SENTINEL_POLL_INTERVAL=43200
POLYMARKET_POLL_INTERVAL=600
MARKET_POLL_INTERVAL=1800
MARKET_POLL_INTERVAL_OFFHOURS=7200
MARKET_HISTORY_DAYS=30

# --- RSSHub ---
RSSHUB_BASE=http://rsshub:1200
SOCIAL_BATCH_SIZE=10

# --- Twitter/X ---
TWITTER_AUTH_TOKEN=
TWITTER_CSRF_TOKEN=

# --- AIS ---
AISSTREAM_API_KEY=

# --- Anthropic (misma key que prod, cap más bajo) ---
ANTHROPIC_API_KEY=

# --- Agent Engine ---
AGENT_TIMEOUT_SECONDS=45
MAX_ANALYSES_PER_HOUR=5
MAX_PARALLEL_ANALYSES=2

# --- Polymarket ---
POLYMARKET_MIN_VOLUME=1000

# --- Copernicus ---
CDSE_USER=
CDSE_PASSWORD=

# --- Report Engine ---
REPORTS_DIR=/app/reports
DAILY_REPORT_HOUR=7
WEEKLY_REPORT_DAY=mon
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
REPORT_RECIPIENTS=

# --- Agent Engine scheduling (staging: cap muy bajo, ciclo inmediato al arrancar) ---
CYCLE_SCHEDULE=6,14,22
CYCLE_HOURS_LOOKBACK=8
ENABLED_AGENTS=adsb,maritime,news,social
DAILY_SPEND_CAP=0.50
SPEND_WARN_THRESHOLD=0.80
FORCE_RUN_CYCLE=true

# --- DB pool (staging: pool pequeño) ---
DB_POOL_MIN=2
DB_POOL_MAX=8
