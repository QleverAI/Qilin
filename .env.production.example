# --- Base de datos ---
DB_USER=qilin
DB_PASSWORD=changeme

# --- OpenSky Network (ADS-B) ---
# Regístrate en https://opensky-network.org → My OpenSky → Client Credentials
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=

# --- Telegram Bot (alertas instantáneas) ---
# Crea un bot con @BotFather en Telegram
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# --- Intervalos de polling (segundos) ---
ADSB_POLL_INTERVAL=15
AIS_POLL_INTERVAL=60

# ── Ingestor Social (RSS + RSSHub) ──────────────────────────
# Intervalo de polling RSS (segundos, default 900 = 15 min)
SOCIAL_POLL_INTERVAL=900
# RSSHub corre como contenedor interno — no cambiar salvo despliegue externo
RSSHUB_BASE=http://rsshub:1200
# Cuentas procesadas en paralelo por lote
SOCIAL_BATCH_SIZE=15

# ── Twitter/X cookies para RSSHub (feeds de cuentas individuales) ──
# Sin estos valores, solo funcionan los RSS oficiales (medios, instituciones).
# Para activar feeds de líderes, militares y think tanks:
#   1. Abre X.com en tu navegador con tu cuenta
#   2. F12 → Application → Cookies → twitter.com
#   3. Copia los valores de auth_token y ct0
TWITTER_AUTH_TOKEN=
TWITTER_CSRF_TOKEN=

# --- Ingestor de noticias RSS ---
# Intervalo de polling RSS (segundos, default 900 = 15 min)
NEWS_POLL_INTERVAL=900

# --- Ingestor de documentos oficiales ---
# Intervalo de polling de portales (segundos, default 3600 = 1 hora)
DOCS_POLL_INTERVAL=3600

# --- Ingestor de filings SEC (8-K) ---
# Intervalo de polling EDGAR (segundos, default 1800 = 30 min)
SEC_POLL_INTERVAL=1800

# --- Sentinel-5P / Copernicus Data Space Ecosystem ---
# Registro gratuito en https://dataspace.copernicus.eu
# Necesario para el ingestor de emisiones atmosféricas NO2/SO2
CDSE_USER=
CDSE_PASSWORD=
# Intervalo de polling en segundos (default 21600 = 6 horas)
SENTINEL_POLL_INTERVAL=21600

# --- AIS (aisstream.io) ---
# API key gratuita en https://aisstream.io
# Reemplaza AISHub (que requería receptor propio)
AISSTREAM_API_KEY=

# --- LLM Enrichment (Anthropic) ---
# Clave de API de Anthropic para enriquecimiento LLM de alertas y agent-engine
# Registrarse en https://console.anthropic.com
# El alert-engine usa claude-haiku-4-5 (bajo coste) para triage
ANTHROPIC_API_KEY=

# --- Agent Engine ---
AGENT_TIMEOUT_SECONDS=45     # Timeout total por análisis (segundos)
MAX_ANALYSES_PER_HOUR=10     # Límite análisis LLM por hora (ventana deslizante)
MAX_PARALLEL_ANALYSES=3      # Máximo análisis simultáneos

# --- Ingestor de Predicciones Polymarket ---
# Intervalo de polling (segundos, default 300 = 5 min)
POLYMARKET_POLL_INTERVAL=300
# Volumen mínimo en USD para considerar un mercado (default 1000)
POLYMARKET_MIN_VOLUME=1000

# --- Ingestor de Mercados Financieros ---
# Intervalo de polling en horario de mercado (segundos, default 900 = 15 min)
MARKET_POLL_INTERVAL=900
# Intervalo fuera de horario de mercado (default 3600 = 1 hora)
MARKET_POLL_INTERVAL_OFFHOURS=3600
# Días de historial OHLCV a descargar diariamente (default 60)
MARKET_HISTORY_DAYS=60

# --- Report Engine ---
# Directorio donde se guardan los PDFs generados (default /app/reports dentro del contenedor)
REPORTS_DIR=/app/reports
# Hora UTC a la que se genera el informe diario (default 7 = 07:00 UTC)
DAILY_REPORT_HOUR=7
# Día de la semana para el informe semanal (mon/tue/wed/thu/fri/sat/sun)
WEEKLY_REPORT_DAY=mon

# --- Envío por Email (SMTP) ---
# Servidor SMTP para enviar los informes por email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
# Lista de destinatarios separados por comas
REPORT_RECIPIENTS=

# ── Scheduled multi-agent intel ──────────────────────────────────────────
CYCLE_SCHEDULE=6,14,22                 # UTC hours, comma-separated
CYCLE_HOURS_LOOKBACK=8
ENABLED_AGENTS=adsb,maritime,news,social
DAILY_SPEND_CAP=5.00
SPEND_WARN_THRESHOLD=0.80
FORCE_RUN_CYCLE=false
